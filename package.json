{
  "name": "letsfocus",
  "version": "1.0.0",
  "private": true,
  "description": "LetsFocus - Pomodoro Timer with Task Management",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "apps/frontend/**/*.{ts,tsx}": [
      "pnpm --filter frontend exec prettier --write",
      "pnpm --filter frontend exec eslint --fix"
    ],
    "apps/backend/**/*.ts": [
      "pnpm --filter backend exec prettier --write",
      "pnpm --filter backend exec eslint --fix"
    ]
  }
}
